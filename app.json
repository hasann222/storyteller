{
  "expo": {
    "name": "Portal",
    "slug": "portal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/portal.png",
    "userInterfaceStyle": "light",
    "scheme": "portal",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/portal.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1428"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/portal.png",
        "backgroundColor": "#1E1428"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.portal",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/portal.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ]
  }
}
